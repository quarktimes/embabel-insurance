# LANGFUSE_PUBLIC_KEY=pk-xxx
# LANGFUSE_SECRET_KEY=sk-xxx
# LANGFUSE_BASE_URL=https://us.cloud.langfuse.com

# OpenWeather API Key（可选，演示用）
# OPENWEATHER_API_KEY=your-api-key
