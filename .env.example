# DeepSeek API Key（必填）
DEEPSEEK_API_KEY=your-deepseek-api-key

# MySQL 数据源（默认值适用于本地开发）
# MYSQL_URL=jdbc:mysql://localhost:3306/embabel_insurance?useSSL=false&allowPublicKeyRetrieval=true&serverTimezone=UTC&createDatabaseIfNotExist=true
# MYSQL_USER=root
# MYSQL_PASSWORD=Embabel@2024!

# Langfuse 可观测性（启动 Langfuse 后，在 UI 中创建 API 密钥）
# 1. docker compose up -d 启动后访问 http://localhost:3000
# 2. 注册账号 → 创建项目 → 创建 API 密钥
# 3. 将生成的公钥和私钥填入下方
LANGFUSE_PUBLIC_KEY=pk-你的公钥
LANGFUSE_SECRET_KEY=sk-你的私钥
LANGFUSE_ENDPOINT=http://localhost:3000/api/public/otel

# OpenWeather API Key（可选，演示用）
# OPENWEATHER_API_KEY=your-api-key
